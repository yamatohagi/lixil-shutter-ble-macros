    <assert-characteristic description="LIXIL shutter write command" uuid="2141e112-213a-11e6-b67b-9e71128cae77">
      <property name="WRITE_WITHOUT_RESPONSE" requirement="MANDATORY"/>
    </assert-characteristic>
    <assert-characteristic description="LIXIL shutter notification" uuid="2141e111-213a-11e6-b67b-9e71128cae77">
      <property name="NOTIFY" requirement="MANDATORY"/>
    </assert-characteristic>
  </assert-service>
  <write description="Open shutter" service-uuid="2141e110-213a-11e6-b67b-9e71128cae77" characteristic-uuid="2141e112-213a-11e6-b67b-9e71128cae77" value="0203" type="WRITE_COMMAND"/>
